---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About | SUNCHEN" description="SUNCHEN's background, technical focus, and contact information.">
  <section class="content-grid about-grid">
    <div class="content-card panel">
      <h2 class="section-title">Current focus</h2>
      <div class="list-block">
        <article class="timeline-item">
          <h3>Embedded Linux Drivers</h3>
          <p>I focus on device drivers, kernel interfaces, hardware-software co-debugging, and more stable low-level system implementations.</p>
        </article>
        <article class="timeline-item">
          <h3>RTOS</h3>
          <p>I continue to build practical understanding of scheduling, interrupts, resource management, and engineering workflows in real-time systems.</p>
        </article>
        <article class="timeline-item">
          <h3>MCU</h3>
          <p>I am interested in peripheral drivers, communication interfaces, board-level debugging, and software design for resource-constrained environments.</p>
        </article>
      </div>
    </div>

    <aside class="content-card panel">
      <h2 class="section-title">Contact and direction</h2>
      <div class="list-block">
        <article class="note-card">
          <h3>Target roles</h3>
          <p>Embedded Linux Drivers / RTOS / MCU</p>
        </article>
        <article class="note-card">
          <h3>Email</h3>
          <p><a class="text-link" href="mailto:schen030@163.com">schen0303@163.com</a></p>
        </article>
        <article class="note-card">
          <h3>Motto</h3>
          <p>Keep Hungry</p>
        </article>
      </div>
    </aside>
  </section>
</BaseLayout>
