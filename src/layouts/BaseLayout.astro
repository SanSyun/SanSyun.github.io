---
import type { Locale } from "../lib/i18n";
import { siteCopy } from "../lib/i18n";

export interface Props {
  title: string;
  description?: string;
  locale?: Locale;
}

const {
  title,
  description = "A publication-style personal site for projects, notes, and writing.",
  locale = "en"
} = Astro.props;

const copy = siteCopy[locale];
---

<!doctype html>
<html lang={copy.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <div class="header-row">
          <div class="brand-block">
            <a class="brand" href={copy.nav[0].href}>SUNCHEN</a>
            <p class="brand-note">{copy.brandNote}</p>
          </div>
          <nav aria-label="Primary">
            <ul class="nav-list">
              {copy.nav.map((item) => (
                <li><a href={item.href}>{item.label}</a></li>
              ))}
            </ul>
          </nav>
        </div>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <p>{copy.footer}</p>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --bg: #ffffff;
    --paper: #ffffff;
    --paper-soft: #f7f9fc;
    --text: #181818;
    --muted: #50555c;
    --border: #d7dde5;
    --accent: #1e2d3f;
    --accent-soft: #16649c;
    --max-width: 1220px;
    --serif: Georgia, "Times New Roman", Times, serif;
    --sans: "Segoe UI", "PingFang SC", "Microsoft YaHei", "Helvetica Neue", Helvetica, Arial, sans-serif;
  }

  * {
    box-sizing: border-box;
    min-width: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    color: var(--text);
    background: var(--bg);
    font-family: var(--sans);
    line-height: 1.7;
    overflow-x: hidden;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  p {
    margin: 0;
    color: var(--muted);
  }

  code {
    font-family: "Cascadia Code", Consolas, monospace;
    overflow-wrap: anywhere;
  }

  pre {
    max-width: 100%;
    overflow-x: auto;
    padding: 0;
    border-radius: 4px;
    background: #f4f4f4;
  }

  pre code {
    overflow-wrap: normal;
    word-break: normal;
    white-space: pre;
  }

  img {
    max-width: 100%;
    display: block;
    height: auto;
  }

  table {
    display: block;
    max-width: 100%;
    overflow-x: auto;
  }

  .page-shell {
    width: min(calc(100% - 32px), var(--max-width));
    margin: 0 auto;
    padding: 0 0 56px;
  }

  .site-header {
    padding: 18px 0 20px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 28px;
  }

  .header-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 24px;
  }

  .brand-block {
    display: grid;
    gap: 6px;
  }

  .brand {
    display: inline-block;
    font-family: var(--serif);
    font-size: 2.7rem;
    font-weight: 700;
    letter-spacing: -0.05em;
    line-height: 0.95;
  }

  .brand-note {
    font-size: 0.95rem;
  }

  .nav-list {
    list-style: none;
    display: flex;
    gap: 24px;
    padding: 6px 0 0;
    margin: 0;
    flex-wrap: wrap;
    justify-content: flex-end;
    font-size: 0.98rem;
    color: var(--text);
    font-weight: 600;
  }

  .nav-list a:hover,
  .nav-list a:focus-visible,
  .text-link:hover,
  .text-link:focus-visible,
  .button-link:hover,
  .button-link:focus-visible,
  .home-section-link:hover,
  .home-section-link:focus-visible,
  .home-headline-link:hover,
  .home-headline-link:focus-visible,
  .toc-list a:hover,
  .toc-list a:focus-visible {
    color: var(--accent-soft);
  }

  .eyebrow {
    font-size: 0.82rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-soft);
  }

  .hero-title,
  .page-title,
  .article-title,
  .section-title,
  .home-section-title,
  .home-headline-link {
    font-family: var(--serif);
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--text);
    overflow-wrap: anywhere;
    text-wrap: balance;
  }

  .hero-title {
    margin: 0;
    font-size: clamp(1.5rem, 2.5vw, 2.2rem);
    line-height: 1.1;
    max-width: 16ch;
  }

  .page-title {
    margin: 0;
    font-size: clamp(2.2rem, 4vw, 3rem);
    line-height: 1.05;
  }

  .article-title {
    margin: 0;
    font-size: clamp(2rem, 4vw, 2.8rem);
    line-height: 1.06;
  }

  .section-title {
    font-size: 2rem;
    margin: 0 0 20px;
  }

  .lede {
    font-size: 0.9rem;
    max-width: 50ch;
  }

  .panel {
    background: var(--paper);
    border: 1px solid var(--border);
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(240px, 0.62fr) minmax(560px, 1.38fr);
    gap: 24px;
    margin-bottom: 34px;
    align-items: stretch;
  }

  .hero-card,
  .sidebar-card,
  .content-card,
  .timeline-item,
  .article-shell {
    border-radius: 0;
    padding: 20px;
  }

  .hero-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    justify-content: center;
    background: var(--paper-soft);
    border-top: 4px solid var(--accent-soft);
  }

  .hero-visual {
    min-height: 0;
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    background: transparent;
    overflow: hidden;
    aspect-ratio: 4793 / 3195;
  }

  .hero-visual img {
    width: 100%;
    height: 100%;
    min-height: 0;
    object-fit: contain;
    object-position: center;
    background: transparent;
  }

  .hero-meta,
  .stack-list,
  .tag-list,
  .stat-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .hero-meta li,
  .stack-list li,
  .tag-list li,
  .stat-list li {
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 7px 12px;
    color: var(--muted);
    font-size: 0.84rem;
    background: #fff;
    overflow-wrap: anywhere;
  }

  .button-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    max-width: 100%;
    padding: 10px 16px;
    border: 1px solid var(--accent-soft);
    color: var(--accent-soft);
    font-weight: 600;
  }

  .text-link,
  .home-section-link {
    color: var(--accent-soft);
  }

  .content-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.32fr) minmax(300px, 0.88fr);
    gap: 24px;
    align-items: start;
  }

  .home-columns {
    display: grid;
    gap: 12px;
  }

  .home-section {
    padding-top: 4px;
  }

  .home-section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding-bottom: 12px;
    margin-bottom: 6px;
    border-bottom: 2px solid #111;
  }

  .home-section-title {
    margin: 0;
    font-size: 1.55rem;
  }

  .home-feature-card {
    display: grid;
    gap: 10px;
    padding: 20px 0;
    border-top: 1px solid var(--border);
  }

  .home-feature-card:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .home-card-topline {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 14px;
    font-size: 0.84rem;
    color: var(--muted);
  }

  .home-card-type {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent-soft);
  }

  .home-headline-link {
    font-size: clamp(1.2rem, 2vw, 1.55rem);
    line-height: 1.12;
  }

  .home-author-line,
  .home-kicker {
    color: var(--muted);
    font-size: 0.92rem;
  }

  .home-cover-card {
    display: grid;
    gap: 12px;
    align-content: start;
    padding: 20px;
    border: 1px solid var(--border);
    background: var(--paper-soft);
  }

  .home-cover-visual {
    min-height: 200px;
    border: 1px solid var(--border);
    background:
      linear-gradient(rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.14)),
      radial-gradient(circle at 30% 24%, rgba(54, 98, 154, 0.88), transparent 18%),
      linear-gradient(135deg, #6f8193 0%, #263343 100%);
  }

  .meta-line {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 14px;
    font-size: 0.9rem;
    color: var(--muted);
    margin-bottom: 10px;
  }

  .list-block {
    display: grid;
    gap: 18px;
  }

  .timeline-item {
    border: 1px solid var(--border);
    background: #fff;
  }

  .note-card {
    padding: 0 0 18px;
    border-bottom: 1px solid var(--border);
  }

  .note-card:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .page-header {
    display: grid;
    gap: 16px;
    margin-bottom: 28px;
  }

  .article-shell {
    max-width: 820px;
    margin: 0 auto;
    background: var(--paper);
    border: 1px solid var(--border);
  }

  .article-layout {
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr);
    gap: 24px;
    align-items: start;
  }

  .article-toc {
    position: sticky;
    top: 28px;
    padding: 22px 20px;
    background: #fff;
    border: 1px solid var(--border);
  }

  .article-toc-title {
    margin: 0 0 14px;
    font-family: var(--serif);
    font-size: 1.05rem;
    color: var(--text);
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 10px;
  }

  .toc-list a {
    display: block;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.5;
    overflow-wrap: anywhere;
  }

  .toc-item-depth-3 {
    padding-left: 14px;
  }

  .article-shell article {
    font-size: 1.03rem;
  }

  .article-shell article h2,
  .article-shell article h3 {
    font-family: var(--serif);
    margin-top: 2.2em;
    color: var(--text);
    scroll-margin-top: 24px;
    overflow-wrap: anywhere;
  }

  .article-shell article p,
  .article-shell article li,
  .article-shell article blockquote {
    color: #2a2825;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .article-shell article ul,
  .article-shell article ol {
    padding-left: 1.25rem;
  }

  .article-shell article blockquote {
    margin: 1.5rem 0;
    padding-left: 1rem;
    border-left: 3px solid var(--accent-soft);
  }

  .article-summary {
    margin: 16px 0 24px;
    font-size: 1.05rem;
    max-width: 60ch;
  }

  .article-topline {
    padding-bottom: 20px;
    margin-bottom: 20px;
    border-bottom: 1px solid var(--border);
  }

  .split-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }

  .small-label {
    display: block;
    margin-bottom: 6px;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent-soft);
  }

  .site-footer {
    margin-top: 64px;
    padding-top: 18px;
    border-top: 1px solid var(--border);
  }

  @media (max-width: 900px) {
    .header-row,
    .hero,
    .content-grid,
    .split-list,
    .article-layout {
      grid-template-columns: 1fr;
      display: grid;
    }

    .header-row {
      gap: 16px;
    }

    .nav-list {
      justify-content: flex-start;
      padding-top: 0;
    }

    .article-toc {
      position: static;
      order: -1;
    }
  }

  @media (max-width: 640px) {
    .page-shell {
      width: min(calc(100% - 20px), var(--max-width));
      padding: 0 0 40px;
    }

    .site-header {
      padding: 14px 0 16px;
      margin-bottom: 18px;
    }

    .brand {
      font-size: 2.1rem;
    }

    .brand-note,
    .nav-list,
    .meta-line,
    .toc-list a {
      font-size: 0.9rem;
    }

    .nav-list {
      gap: 10px 16px;
    }

    .hero-title {
      font-size: clamp(1.4rem, 5.8vw, 1.8rem);
      max-width: none;
    }

    .page-title {
      font-size: clamp(2rem, 8vw, 2.5rem);
    }

    .article-title {
      font-size: clamp(1.8rem, 7vw, 2.3rem);
    }

    .lede,
    .article-summary,
    .article-shell article {
      font-size: 0.95rem;
    }

    .hero-card,
    .sidebar-card,
    .content-card,
    .timeline-item,
    .article-shell,
    .article-toc,
    .home-cover-card {
      padding: 18px;
    }

    .hero,
    .content-grid,
    .list-block {
      gap: 16px;
    }

    .hero-visual {
      min-height: 300px;
      padding: 0;
    }

    .hero-visual img {
      min-height: 280px;
    }

    .split-list {
      gap: 16px;
    }

    .article-topline {
      padding-bottom: 16px;
      margin-bottom: 16px;
    }
  }
</style>


