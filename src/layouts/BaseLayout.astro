---
import type { Locale } from "../lib/i18n";
import { siteCopy } from "../lib/i18n";

export interface Props {
  title: string;
  description?: string;
  locale?: Locale;
}

const {
  title,
  description = "A publication-style personal site for projects, notes, and writing.",
  locale = "en"
} = Astro.props;

const copy = siteCopy[locale];
---

<!doctype html>
<html lang={copy.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <div class="header-row">
          <div class="brand-block">
            <a class="brand" href={copy.nav[0].href}>SUNCHEN</a>
            <p class="brand-note">{copy.brandNote}</p>
          </div>
          <nav aria-label="Primary">
            <ul class="nav-list">
              {copy.nav.map((item) => (
                <li><a href={item.href}>{item.label}</a></li>
              ))}
            </ul>
          </nav>
        </div>
      </header>

      <main>
        <slot />
      </main>

      {copy.footer && (
        <footer class="site-footer">
          <p>{copy.footer}</p>
        </footer>
      )}
    </div>
    <script is:inline>
      const formatCodeLanguage = (raw) => {
        if (!raw) return "Text";
        const normalized = raw.toLowerCase();
        const labels = {
          js: "JavaScript",
          ts: "TypeScript",
          sh: "Shell",
          bash: "Bash",
          zsh: "Zsh",
          c: "C",
          cpp: "C++",
          py: "Python",
          yaml: "YAML",
          yml: "YAML",
          md: "Markdown",
          make: "Makefile",
          makefile: "Makefile",
          text: "Text",
          plaintext: "Text"
        };
        return labels[normalized] ?? raw;
      };

      const detectCodeLanguage = (pre) => {
        const code = pre.querySelector("code");
        const classNames = [pre.className, code?.className ?? ""].join(" ");
        const classMatch = classNames.match(/language-([\w+-]+)/i);
        return code?.dataset.language || pre.dataset.language || classMatch?.[1] || "text";
      };

      const enhanceCodeBlocks = () => {
        document.querySelectorAll(".article-shell article pre").forEach((pre) => {
          if (pre.parentElement?.classList.contains("code-block-shell")) return;

          const shell = document.createElement("div");
          shell.className = "code-block-shell";

          const toolbar = document.createElement("div");
          toolbar.className = "code-block-toolbar";

          const language = document.createElement("span");
          language.className = "code-block-language";
          language.textContent = formatCodeLanguage(detectCodeLanguage(pre));

          const copyButton = document.createElement("button");
          copyButton.type = "button";
          copyButton.className = "code-block-copy";
          copyButton.setAttribute("aria-label", "复制代码");
          copyButton.setAttribute("title", "复制代码");
          copyButton.innerHTML = `
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M9 7a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2h-8a2 2 0 0 1-2-2z"></path>
              <path d="M5 15a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2"></path>
            </svg>
          `;
          copyButton.addEventListener("click", async () => {
            const text = pre.querySelector("code")?.innerText ?? pre.innerText;
            try {
              await navigator.clipboard.writeText(text);
              copyButton.dataset.state = "copied";
              copyButton.disabled = true;
              window.setTimeout(() => {
                delete copyButton.dataset.state;
                copyButton.disabled = false;
              }, 1400);
            } catch {
              copyButton.dataset.state = "failed";
              window.setTimeout(() => {
                delete copyButton.dataset.state;
              }, 1400);
            }
          });

          toolbar.append(language, copyButton);
          pre.before(shell);
          shell.append(toolbar, pre);
        });
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", enhanceCodeBlocks, { once: true });
      } else {
        enhanceCodeBlocks();
      }

      document.addEventListener("astro:page-load", enhanceCodeBlocks);

      const setupArticleToc = () => {
        const toc = document.querySelector("[data-article-toc]");
        const article = document.querySelector("[data-article-content]");
        if (!toc || !article) return;

        const tocLinks = Array.from(toc.querySelectorAll("[data-toc-link]"));
        if (!tocLinks.length) return;

        const headingEntries = tocLinks
          .map((link) => {
            const id = decodeURIComponent(link.getAttribute("href")?.slice(1) ?? "");
            if (!id) return null;
            const heading = article.querySelector(`#${CSS.escape(id)}`);
            if (!heading) return null;
            return { id, link, heading };
          })
          .filter(Boolean);

        if (!headingEntries.length) return;

        let activeId = "";
        let suspendAutoScrollUntil = 0;

        const markTocInteraction = () => {
          suspendAutoScrollUntil = window.setTimeout ? Date.now() + 1200 : 0;
        };

        toc.addEventListener("wheel", markTocInteraction, { passive: true });
        toc.addEventListener("touchmove", markTocInteraction, { passive: true });
        toc.addEventListener("pointerenter", markTocInteraction);

        const syncActiveLink = (id) => {
          if (!id || activeId === id) return;
          activeId = id;

          headingEntries.forEach((entry) => {
            const isActive = entry.id === id;
            entry.link.classList.toggle("is-active", isActive);
            entry.link.setAttribute("aria-current", isActive ? "true" : "false");
          });

          if (Date.now() < suspendAutoScrollUntil) return;

          const activeEntry = headingEntries.find((entry) => entry.id === id);
          if (!activeEntry) return;

          const linkBox = activeEntry.link.getBoundingClientRect();
          const tocBox = toc.getBoundingClientRect();
          const padding = 20;
          const outOfView =
            linkBox.top < tocBox.top + padding ||
            linkBox.bottom > tocBox.bottom - padding;

          if (outOfView) {
            const targetTop =
              activeEntry.link.offsetTop - toc.clientHeight / 2 + activeEntry.link.clientHeight / 2;
            toc.scrollTo({
              top: Math.max(0, targetTop),
              behavior: "smooth"
            });
          }
        };

        const updateActiveHeading = () => {
          const threshold = 140;
          let current = headingEntries[0];

          for (const entry of headingEntries) {
            const top = entry.heading.getBoundingClientRect().top;
            if (top <= threshold) {
              current = entry;
            } else {
              break;
            }
          }

          syncActiveLink(current.id);
        };

        updateActiveHeading();
        window.addEventListener("scroll", updateActiveHeading, { passive: true });
        window.addEventListener("resize", updateActiveHeading);
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", setupArticleToc, { once: true });
      } else {
        setupArticleToc();
      }

      document.addEventListener("astro:page-load", setupArticleToc);
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg: #ffffff;
    --paper: #ffffff;
    --paper-soft: #f6f8f7;
    --text: #181818;
    --muted: #50555c;
    --border: #d7dde5;
    --accent: #1e2d3f;
    --accent-soft: #0b7285;
    --accent-warm: #9a5a18;
    --max-width: 1220px;
    --serif: Georgia, "Times New Roman", Times, serif;
    --sans: "Segoe UI", "PingFang SC", "Microsoft YaHei", "Helvetica Neue", Helvetica, Arial, sans-serif;
  }

  * {
    box-sizing: border-box;
    min-width: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    color: var(--text);
    background: var(--bg);
    font-family: var(--sans);
    line-height: 1.7;
    overflow-x: hidden;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  p {
    margin: 0;
    color: var(--muted);
  }

  code {
    font-family: "Cascadia Code", Consolas, monospace;
    overflow-wrap: anywhere;
  }

  pre {
    max-width: 100%;
    overflow-x: auto;
    padding: 0;
    border-radius: 4px;
    background: #f4f4f4;
  }

  pre code {
    overflow-wrap: normal;
    word-break: normal;
    white-space: pre;
  }

  img {
    max-width: 100%;
    display: block;
    height: auto;
  }

  table {
    display: block;
    max-width: 100%;
    overflow-x: auto;
  }

  .page-shell {
    width: min(calc(100% - 32px), var(--max-width));
    margin: 0 auto;
    padding: 0 0 56px;
  }

  .site-header {
    padding: 18px 0 20px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 28px;
  }

  .header-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 24px;
  }

  .brand-block {
    display: grid;
    gap: 6px;
  }

  .brand {
    display: inline-block;
    font-family: var(--serif);
    font-size: 2.7rem;
    font-weight: 700;
    letter-spacing: -0.05em;
    line-height: 0.95;
  }

  .brand-note {
    font-size: 0.95rem;
  }

  .nav-list {
    list-style: none;
    display: flex;
    gap: 24px;
    padding: 6px 0 0;
    margin: 0;
    flex-wrap: wrap;
    justify-content: flex-end;
    font-size: 0.98rem;
    color: var(--text);
    font-weight: 600;
  }

  .nav-list a:hover,
  .nav-list a:focus-visible,
  .text-link:hover,
  .text-link:focus-visible,
  .home-section-link:hover,
  .home-section-link:focus-visible,
  .home-headline-link:hover,
  .home-headline-link:focus-visible,
  .toc-list a:hover,
  .toc-list a:focus-visible {
    color: var(--accent-soft);
  }

  .eyebrow {
    font-size: 0.82rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-soft);
  }

  .hero-title,
  .page-title,
  .article-title,
  .section-title,
  .home-section-title,
  .home-headline-link {
    font-family: var(--serif);
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--text);
    overflow-wrap: anywhere;
    text-wrap: balance;
  }

  .hero-title {
    margin: 0;
    font-size: 3.2rem;
    line-height: 1.04;
    max-width: 760px;
  }

  .page-title {
    margin: 0;
    font-size: 3rem;
    line-height: 1.05;
  }

  .article-title {
    margin: 0;
    font-size: 2.8rem;
    line-height: 1.06;
  }

  .section-title {
    font-size: 2rem;
    margin: 0 0 20px;
  }

  .lede {
    font-size: 1rem;
    max-width: 64ch;
  }

  .panel {
    background: var(--paper);
    border: 1px solid var(--border);
  }

  .home-hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 410px;
    padding: 34px;
    margin-bottom: 36px;
    overflow: hidden;
    border: 1px solid var(--border);
    background:
      linear-gradient(rgba(5, 17, 22, 0.1), rgba(5, 17, 22, 0.36)),
      url("/images/home/bg-pattern.png") center / cover no-repeat;
  }

  .hero-card,
  .sidebar-card,
  .content-card,
  .timeline-item,
  .article-shell {
    border-radius: 0;
    padding: 20px;
  }

  .home-hero-glass {
    width: 33.333%;
    min-width: 360px;
    max-width: 440px;
    padding: 22px 26px;
    border: 1px solid rgba(255, 255, 255, 0.42);
    border-radius: 8px;
    background: rgba(8, 24, 29, 0.34);
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.16);
    backdrop-filter: blur(18px) saturate(140%);
    -webkit-backdrop-filter: blur(18px) saturate(140%);
  }

  .home-hero-label {
    display: block;
    color: #ffffff;
    font-size: 1.12rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    line-height: 1.3;
    text-align: center;
    text-transform: uppercase;
    text-shadow: 0 1px 18px rgba(0, 0, 0, 0.28);
    overflow-wrap: anywhere;
  }

  .stack-list,
  .tag-list,
  .stat-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .stack-list li,
  .tag-list li,
  .stat-list li {
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 7px 12px;
    color: var(--muted);
    font-size: 0.84rem;
    background: #fff;
    overflow-wrap: anywhere;
  }

  .text-link,
  .home-section-link {
    color: var(--accent-soft);
  }

  .content-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.32fr) minmax(300px, 0.88fr);
    gap: 24px;
    align-items: start;
  }

  .about-grid {
    align-items: stretch;
  }

  .about-grid > .content-card {
    height: 100%;
    display: flex;
    flex-direction: column;
    padding: 16px;
  }

  .about-grid .section-title {
    margin-bottom: 14px;
  }

  .about-grid .list-block {
    gap: 12px;
  }

  .about-grid .timeline-item {
    padding: 14px;
  }

  .about-grid .timeline-item h3,
  .about-grid .note-card h3 {
    margin-bottom: 6px;
  }

  .about-grid .note-card {
    padding: 0 0 12px;
  }

  .about-grid .timeline-item p,
  .about-grid .note-card p {
    line-height: 1.6;
  }

  .home-feed-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 36px;
    align-items: start;
  }

  .home-section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding: 0 0 14px;
    margin-bottom: 2px;
    border-bottom: 2px solid var(--text);
  }

  .home-section-title {
    margin: 0;
    font-size: 1.65rem;
  }

  .home-feature-card {
    display: grid;
    gap: 10px;
    padding: 20px 0;
    border-top: 1px solid var(--border);
  }

  .home-section-header + .home-feature-card {
    border-top: 0;
  }

  .home-card-topline {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 14px;
    font-size: 0.84rem;
    color: var(--muted);
  }

  .home-card-type {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent-soft);
  }

  .home-headline-link {
    font-size: 1.38rem;
    line-height: 1.12;
  }

  .home-feature-card p {
    font-size: 0.96rem;
    line-height: 1.62;
  }

  .home-author-line,
  .home-kicker {
    color: var(--muted);
    font-size: 0.92rem;
  }

  .meta-line {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 14px;
    font-size: 0.9rem;
    color: var(--muted);
    margin-bottom: 10px;
  }

  .list-block {
    display: grid;
    gap: 18px;
  }

  .timeline-item {
    border: 1px solid var(--border);
    background: #fff;
  }

  .note-card {
    padding: 0 0 18px;
    border-bottom: 1px solid var(--border);
  }

  .note-card:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .page-header {
    display: grid;
    gap: 16px;
    margin-bottom: 28px;
  }

  .article-shell {
    width: min(100%, 820px);
    margin: 0;
    background: var(--paper);
    border: 1px solid var(--border);
  }

  .article-layout {
    display: grid;
    grid-template-columns: minmax(220px, 280px) minmax(0, 820px);
    justify-content: center;
    gap: 28px;
    align-items: start;
  }

  .article-toc {
    position: sticky;
    top: 20px;
    max-height: calc(100vh - 40px);
    overflow-y: auto;
    overscroll-behavior: contain;
    scrollbar-gutter: stable;
    padding: 22px 20px;
    background: #fff;
    border: 1px solid var(--border);
  }

  .article-toc-title {
    margin: 0 0 14px;
    font-family: var(--serif);
    font-size: 1.05rem;
    color: var(--text);
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 10px;
  }

  .toc-list a {
    display: block;
    padding: 2px 0;
    color: var(--muted);
    font-size: 0.94rem;
    line-height: 1.6;
    overflow-wrap: anywhere;
    transition: color 0.18s ease;
  }

  .toc-list a.is-active {
    color: var(--accent-soft);
    font-weight: 700;
  }

  .toc-item-depth-1 a {
    font-weight: 700;
    color: var(--text);
  }

  .toc-item-depth-2 {
    padding-left: 16px;
  }

  .toc-item-depth-2 a {
    font-size: 0.9rem;
  }

  .article-shell article {
    font-size: 1.03rem;
  }

  .article-shell article h2,
  .article-shell article h3 {
    font-family: var(--serif);
    margin-top: 2.2em;
    color: var(--text);
    scroll-margin-top: 24px;
    overflow-wrap: anywhere;
  }

  .article-shell article p,
  .article-shell article li,
  .article-shell article blockquote {
    color: #2a2825;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .article-shell article ul,
  .article-shell article ol {
    padding-left: 1.25rem;
  }

  .article-shell article blockquote {
    margin: 1.5rem 0;
    padding-left: 1rem;
    border-left: 3px solid var(--accent-soft);
  }

  .article-shell article .code-block-shell {
    margin: 1.2rem 0;
    border: 0;
    border-radius: 0;
    overflow: hidden;
    background: #edf3f6;
  }

  .article-shell article .code-block-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 5px 9px;
    background: #38c2e5;
  }

  .article-shell article .code-block-language {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.7rem;
    line-height: 1;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 700;
  }

  .article-shell article .code-block-language::before {
    content: "";
    width: 6px;
    height: 6px;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: rotate(45deg) translateY(-1px);
  }

  .article-shell article .code-block-copy {
    appearance: none;
    position: relative;
    width: 20px;
    height: 20px;
    border: 0;
    background: transparent;
    color: #ffffff;
    border-radius: 4px;
    padding: 0;
    cursor: pointer;
    transition: background-color 0.18s ease, opacity 0.18s ease;
  }

  .article-shell article .code-block-copy svg {
    width: 14px;
    height: 14px;
    display: block;
    margin: 0 auto;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .article-shell article .code-block-copy:hover,
  .article-shell article .code-block-copy:focus-visible {
    background: rgba(255, 255, 255, 0.14);
    outline: none;
  }

  .article-shell article .code-block-copy:disabled {
    cursor: default;
  }

  .article-shell article .code-block-copy[data-state="copied"] {
    color: #d8fff2;
  }

  .article-shell article .code-block-copy[data-state="failed"] {
    color: #ffe1e1;
  }

  .article-shell article .code-block-shell pre {
    margin: 0;
    padding: 1px 0;
    border: 0;
    border-radius: 0;
    background: #edf3f6 !important;
  }

  .article-shell article .code-block-shell pre code {
    display: block;
    font-size: 0.82rem;
    line-height: 1.15;
    white-space: pre;
    counter-reset: code-line;
  }

  .article-shell article .code-block-shell pre code .line {
    position: relative;
    display: block;
    min-height: 1.16em;
    padding: 0 10px 0 40px;
  }

  .article-shell article .code-block-shell pre code .line::before {
    counter-increment: code-line;
    content: counter(code-line);
    position: absolute;
    left: 0;
    top: 0;
    width: 26px;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #8adfe4;
    color: #ffffff;
    font-family: "Cascadia Code", Consolas, monospace;
    font-size: 0.68rem;
    line-height: 1;
  }

  .article-shell article .code-block-shell pre code .line:empty::after {
    content: " ";
  }

  .article-summary {
    margin: 16px 0 24px;
    font-size: 1.05rem;
    max-width: 60ch;
  }

  .article-topline {
    padding-bottom: 20px;
    margin-bottom: 20px;
    border-bottom: 1px solid var(--border);
  }

  .split-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }

  .small-label {
    display: block;
    margin-bottom: 6px;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent-soft);
  }

  .site-footer {
    margin-top: 64px;
    padding-top: 18px;
    border-top: 1px solid var(--border);
  }

  @media (max-width: 900px) {
    .header-row,
    .home-feed-grid,
    .content-grid,
    .split-list,
    .article-layout {
      grid-template-columns: 1fr;
      display: grid;
    }

    .header-row {
      gap: 16px;
    }

    .nav-list {
      justify-content: flex-start;
      padding-top: 0;
    }

    .hero-title {
      font-size: 2.75rem;
      max-width: 720px;
    }

    .home-hero {
      min-height: 340px;
      padding: 28px;
    }

    .article-toc {
      position: static;
      order: -1;
      max-height: none;
      overflow: visible;
    }
  }

  @media (max-width: 640px) {
    .page-shell {
      width: min(calc(100% - 20px), var(--max-width));
      padding: 0 0 40px;
    }

    .site-header {
      padding: 14px 0 16px;
      margin-bottom: 18px;
    }

    .brand {
